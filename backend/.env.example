# ─────────────────────────────────────────────
# Cocon — squelette d'environnement
# Copier ce fichier en `.env` et remplir les valeurs.
# Le `.env` réel est gitignored.
# ─────────────────────────────────────────────

# ─── TMDb ────────────────────────────────────
TMDB_API_KEY=
TMDB_READ_TOKEN=
TMDB_LANGUAGE=fr-FR

# ─── Google Maps Platform ────────────────────
# Restreindre par IP du VPS + APIs activées (Places, Maps Static)
GOOGLE_MAPS_API_KEY=

# ─── Configuration app ───────────────────────
APP_HOST=127.0.0.1
APP_PORT=8765
# local | production
APP_ENV=local

# Prod : origines autorisées si le front est sur un autre domaine (sinon laisser vide)
# CORS_ORIGINS=https://jttof.tondomaine.fr

# Optionnel. Si vide, la base est créée dans <project_root>/data/jttof.db
# DATABASE_URL=sqlite:////chemin/absolu/vers/jttof.db

# ─── Auth ────────────────────────────────────
# Token partagé pour Basic Auth (côté Nginx ou middleware FastAPI).
# Laisser vide en local, définir avant déploiement.
APP_SHARED_TOKEN=
